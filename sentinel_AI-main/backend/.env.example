# ================================================================
# SentinelAI Core Settings
# ================================================================
PROJECT_NAME="SentinelAI"
API_V1_STR="/api/v1"
SECRET_KEY="production-level-secure-random-secret-key"
ACCESS_TOKEN_EXPIRE_MINUTES=60
ENVIRONMENT="development"  # development, staging, production

# ================================================================
# Database Connections
# ================================================================
# PostgreSQL
DATABASE_HOST="localhost"
DATABASE_PORT=5432
DATABASE_USER="postgres"
DATABASE_PASSWORD="secure_postgres_password"
DATABASE_NAME="sentinelai"

# Neo4j Graph Database
NEO4J_URI="bolt://localhost:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="secure_neo4j_password"

# Redis Cache & Rate Limiting
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""

# ================================================================
# AI Models & APIs
# ================================================================
# Gemini API Configuration
GEMINI_API_KEY="AIzaSyYourGeminiApiKeyHere"
GEMINI_MODEL="gemini-2.0-flash-thinking"

# Spatio-Temporal Prediction Thresholds
HOTSPOT_ALERT_THRESHOLD=0.75

# ================================================================
# Integrations
# ================================================================
# Keycloak Authorization (Zero Trust OpenID Connect)
KEYCLOAK_URL="http://localhost:8080"
KEYCLOAK_REALM="sentinelai"
KEYCLOAK_CLIENT_ID="sentinelai-backend"

# Telemetry & Observability
OPENTELEMETRY_ENABLED=true
JAEGER_ENDPOINT="http://localhost:4317"
LOG_LEVEL="INFO"
